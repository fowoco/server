# 기본값은 local(H2)입니다. PostgreSQL은 dev 또는 prod로 바꿉니다.
SPRING_PROFILES_ACTIVE=local

# PostgreSQL(dev/prod)에서만 사용합니다.
DB_URL=jdbc:postgresql://localhost:5432/fowoco
DB_USERNAME=postgres
DB_PASSWORD=

# React 개발 서버 또는 배포 Client 주소를 쉼표로 구분합니다.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Access Token 서명 키입니다. dev/prod에서는 반드시 32바이트 이상의 난수를 Base64로 넣습니다.
# 생성 예시: openssl rand -base64 32
# local 프로필은 로컬 전용 기본 키를 사용합니다. dev/prod로 바꿀 때 아래 줄을 활성화하세요.
# JWT_SECRET_BASE64=
# prod는 환경별 issuer와 audience도 반드시 지정해야 합니다.
# JWT_ISSUER=fowoco-server-prod
# JWT_AUDIENCE=fowoco-client-prod
JWT_ACCESS_TOKEN_TTL=15m

# Refresh Token 원문은 Cookie로만 전달되고 DB에는 SHA-256 hash만 저장됩니다.
REFRESH_TOKEN_TTL=14d
REFRESH_TOKEN_COOKIE_NAME=fowoco_refresh_token
REFRESH_TOKEN_COOKIE_SAME_SITE=Strict
# local=false, dev/prod=true가 기본입니다. HTTPS 정책을 바꿀 때만 명시하세요.
# REFRESH_TOKEN_COOKIE_SECURE=true

# 선택 사항: local/dev/demo 환경에서 로그인 가능한 초기 ADMIN 계정을 한 번 생성합니다.
# 기본값은 false이며, true로 켤 때 비밀번호를 반드시 실행 환경의 Secret으로 넣습니다.
# 실제 비밀번호를 이 파일이나 Git에 커밋하지 않습니다.
DEMO_SEED_ENABLED=false
# DEMO_SEED_ADMIN_PASSWORD=
# DEMO_SEED_ADMIN_EMAIL=demo.admin@example.com
# DEMO_SEED_COMPANY_NAME=FOWOCO Demo Company
